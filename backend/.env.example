# Database (Neon). Either name works:
# DATABASE_URL=postgresql+psycopg://USER:PASS@EP-xxx.neon.tech/neondb?sslmode=require
# DB_URL=postgresql://...

# App JWT (HS256) for API auth after GitHub login
JWT_SECRET=change-me-use-long-random

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Frontend and API (OAuth redirect + checkout return URLs)
FRONTEND_URL=http://localhost:3000
APP_PUBLIC_URL=http://localhost:8000
DB_URL="postgresql://neondb_owner:npg_Er05tFDhTnQs@ep-curly-sky-an8mc4wc-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Dodo Payments (https://dodopayments.com)
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENV=test_mode
# Product IDs from Dodo dashboard — wired to Pro / Pro+ plans
